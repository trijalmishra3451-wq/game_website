                        movePiece(last_click_square,detail);
                    }
                }
                
                last_click_square=detail;
                if (detail.style.backgroundColor != "yellow"){
                    detail.style.backgroundColor = "yellow";
                }
            }
            function rule (lastClickedPiece, currentPiece){
                /*
                Note: The current_id and id varibles are only numbers, so use 
                the document selector to use collision detection.
                */
                //this is for the id and their values
                let teamColor = getColor(lastClickedPiece);
                let id=parseInt(lastClickedPiece.id);
                let currentId=parseInt(currentPiece.id);
                let idDiff=currentId-id;
                let absolute_idDiff = Math.abs(idDiff)
                let current_space_color = currentPiece.classList[0];
                let past_space_color = lastClickedPiece.classList[0];
                //these are for horozontal collision
                
                let pastY = cord_translations[id];
                let currentY = cord_translations[currentId];
                currentY = decode(currentY);
                pastY = decode(pastY);
                let is_on_same_rank = currentY == pastY;
                let b = id;
                let amount_of_classes = document.getElementById(b).classList.length;
                let alone = amount_of_classes == 1;
                // this is for diagonal logic
                let form = -1;
                let change = change = 1*form;
                let canMove = canDivide(idDiff,9)|| canDivide(idDiff,7);
                let is_SameColor = current_space_color == past_space_color;
                
                //This first if statement is to prevent suicide by the way
                if(lastClickedPiece.classList[1]==currentPiece.classList[1]){
                    return false;
                }
                switch(lastClickedPiece.classList[1]){
                    /*
                    Note: The pawn was the first piece remake where readability
                    was a priority.
                    */
                    case "black-pawn":
                        /*move range is used as an adaptive value which can work
                        for both pawn versions. In earlier versions, I had to put
                        the indivisual values for the move ranges. But now, I
                        toggle the moveranges to combine both versions
                        */
                        let selected_element = id+pawn_move_range;
                        let square_infront_class_amount = document.getElementById(selected_element).classList.length;
                        
                        if (currentPiece.classList.length > 1){
                            if (absolute_idDiff == 9 || absolute_idDiff == 7){
                                return true;
                            }
                            return false;
                        }else{
                            
                            let black_second_row = id >= 9 && 16 >= id;
                            let white_second_row = id >= 49 && 56 >= id;
                            let in_range = (black_second_row||white_second_row);
                            
                            if (idDiff > 16){
                                console.log('afaf')
                                return false
                            }
                            console.log('afafaf')
                            if (idDiff == pawn_move_range){
                                return true;
                            }else{
                                if (idDiff != pawn_move_range*2 ||!in_range|| square_infront_class_amount > 1){
                                    console.log('my eyes decive')
                                    return false;
                                }
                            }
                            console.log('aa');
                            return true;
                        }
                        break;
                    case "black-rook":
                    case "white-rook":
                        /*this first block of logic is to catch outliers before
                        spending times in the loops.
                        */
                        if (!canDivide(idDiff,8) && !is_on_same_rank){
                            return false;
                        }
                        //Form is used to edit the change in a readable
                        if(idDiff > 0){
                            form = 1;
                        }
                        if(canDivide(idDiff,8)){
                            change = 8*form;
                        }
                        console.log(change);
                        while(b!= currentId){
                            if (!alone && b!=currentId && b != id){
                                console.log(b+' square "'+document.getElementById(b).classList + '" and the amount of classes: '+amount_of_classes);
                                return false;
                            }
                            if (b == currentId){
                                break;
                            }
                            b += change;
                            console.log(b);
                            amount_of_classes = document.getElementById(b).classList.length;
                            alone = amount_of_classes == 1;
                        }
                        return true;
                    case "black-bishop":
                    case "white-bishop":    
                        if (is_SameColor && canMove){
                            if (idDiff < 0){
                                form = -1;
                            }
                            if (canDivide(idDiff,7)){
                                change = 7*form
                            }else{
                                change = 9*form
                            }
                            console.log("The change is equal to "+change)
                            while(b!= currentId){
                                if (!alone && b!=currentId && b != id){
                                    console.log(b+' square "'+document.getElementById(b).classList + '" and the amount of classes: '+amount_of_classes);
                                    return false;
                                }
                                if (b == currentId){
                                    break;
                                }
                                b += change;
                                console.log(b);
                                amount_of_classes = document.getElementById(b).classList.length;
                                alone = amount_of_classes == 1;
                            }
                            return true;
                        }
                    case "black-knight":
                    case "white-knight":
                        switch(absolute_idDiff){
                            case 15:
                            case 17:
                            case 10:
                            case 6:
                                return true;
                            default:
                                return false;
                        }
                        break;
                    case "black-king":
                    case "white-king":
                        switch (absolute_idDiff){
                            case 8:
                                return true;
                            case 9:
                            case 7:
                                return true;
                            case 1:
                                return true;
                        }
                        return false;
                    case "black-queen":
                    case "white-queen":
                        if(!canDivide(idDiff,8)&&!is_on_same_rank&&!canMove){
                            return false;
                        }
                        if(idDiff > 0){
                            form = 1;
                        }
                        switch(idDiff){
                            case canDivide(idDiff,8):
                                change = 8*form;
                                break;
                            case canDivide(idDiff,9):
                                change = 9*form;
                                break;
                            case canDivide(idDiff,7):
                                change = 7*form
                            default:
                                change = 1*form
                        }
                        console.log(change);
                        while(b!= currentId){
                            if (!alone && b!=currentId && b != id){
                                console.log(b+' square "'+document.getElementById(b).classList + '" and the amount of classes: '+amount_of_classes);
                                return false;
                            }
                            if (b == currentId){
                                break;
                            }
                            b += change;
                            console.log(b);
                            amount_of_classes = document.getElementById(b).classList.length;
                            alone = amount_of_classes == 1;
                        }
                        return true;
                    }
                    return false;
                    current_space_color = currentPiece.classList[0];
                    past_space_color = lastClickedPiece.classList[0];
                }
            
            function getColor(selector){
                let teamColorUnprocessed = selector.className.split('-')[0];
                let teamColor = teamColorUnprocessed.split(' ');
                return teamColor[1];
            }
            function movePiece(lastClickedPiece, currentPiece) {
                teamColor = getColor(lastClickedPiece)
                if(teamColor != pastTeamColor && currentPiece.classList[1]!='duck'){
                    if (lastClickedPiece.classList.length > 1 && currentPiece.classList.length == 1) {
                        
                        const pieceClassName = lastClickedPiece.classList[1];
                        currentPiece.classList.add(pieceClassName.trim());
    
                        lastClickedPiece.classList.remove(pieceClassName);
                        toggle();
                        pastTeamColor = teamColor
                        teamColor = null
                        console.log(`Moved ${pieceClassName} successfully!`);
                    }else{
                       if (currentPiece.classList.length > 1){
                           tagsCurrent = currentPiece.classList[1];
                           tagsPast = lastClickedPiece.classList[1];
                           tagscurrent = tagsCurrent.split('-');
                           tagspast = tagsPast.split('-');
                           
                           if(tagscurrent[0]!=tagspast[0]){
                                const pastpieceClassName = lastClickedPiece.classList[1];
                                const currentpieceName = currentPiece.classList[1];
                               
                                // 2. Add that class to the new square
                                currentPiece.classList.remove(currentpieceName);
                                if (currentpieceName == 'white-king' || currentpieceName == 'black-king'){
                                    alert("The king has died, the round will now reset");
                                    reset(false);
                                }
                                lastClickedPiece.classList.remove(pastpieceClassName);
                                currentPiece.classList.add(pastpieceClassName);
                                // 3. Remove that class from the old square
                                toggle();
                                pastTeamColor = teamColor;
                                teamColor = null;
                            }
                                    
                       }
                       console.log("No pieces found to move")
                    }
                }
            }
            function decode(inputlocat) {
            const wordArray = inputlocat.split(",");
            
             return {
                lx: Number(wordArray[0]),
                ly: Number(wordArray[1])
            };
        }
