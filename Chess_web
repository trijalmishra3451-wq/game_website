                }
            }
            function rule (lastClickedPiece, currentPiece)
            {
                var id=parseInt(lastClickedPiece.id);
                var currentId=parseInt(currentPiece.id);
                var idDiff=currentId-id;
                var absolute_idDiff = Math.abs(idDiff)
                var current_space_color = currentPiece.style.backgroundColor;
                var past_space_color = lastClickedPiece.style.backgroundColor;
               if(lastClickedPiece.classList[1]==currentPiece.classList[1])
               {
                   return;
               }
               
                switch(lastClickedPiece.classList[1])
                 {
                    case "black-pawn":
                        var singleMove = parseInt(id)+8
                        if (currentPiece.classList.length > 1){
                            if (idDiff == 9 || idDiff == 7){
                                if (turn== 'black'){
                                    return true; 
                                }
                            }else{
                                return false;
                            }
                        }else{
                            if(singleMove!=parseInt(currentId)){
                                 return false;
                            }else{
                                if (turn = 'black'){
                                    return true;
                                }
                            }
                        }
                        break;
                    case "white-pawn":
                        var singleMove = parseInt(id)-8
                        var inverted_idDiff = idDiff *(-1)
                        if (turn == 'white'){
                            if (currentPiece.classList.length > 1){
                                if (inverted_idDiff == 9 || inverted_idDiff == 7){
                                    return true;
                                }else{
                                    return false;
                                }
                            }else{
                                if(singleMove!=parseInt(currentId)){
                                     return false;
                                }else{
                                    return true;
                                }
                            }
                        }
                        break;
                    case "black-rook":
                    case "white-rook":    
                        if (idDiff%8 == 0){
                            /*
                            Note: This is the first chess piece with implemented collison
                            The rook checks if it can move by lopping between the
                            spaces with between the rook and destination. There 
                            are 2 variations which will be trigered depending on
                            if the rook is going up or down.
                            */
                            if (idDiff < 0){
                                //Travling up
                                var b = id;
                                b -= 8
                                while(b>currentId){
                                    var amount_of_classes = document.getElementById(b).classList.length
                                    
                                    if (amount_of_classes > 1 && b>currentId){
                                        console.log(b+" class num"+document.getElementById(b).classList.length);
                                        return false;
                                    }else{
                                        console.log(b);
                                        b = b-8;
                                    }
                                }
                                return true;
                            }else{
                                //travling down
                                var d = id;
                                d += 8
                                while(d<currentId){
                                    var amount_of_classes = document.getElementById(d).classList.length
                                    
                                    if (amount_of_classes > 1 && d<currentId){
                                        return false;
                                    }else{
                                        console.log(d);
                                        d = d+8;
                                    }
                                }
                                return true;
                            }
                        }else{
                                var pastY = cord_translations[id]
                                var currentY = cord_translations[currentId]
                                currentY = decode(currentY)
                                pastY = decode(pastY)
                                if(pastY.ly == currentY.ly){
                                    return true;
                                }else{
                                    return false;
                                }
                        }
                        break;
                    case "black-bishop":
                    case "white-bishop":    
                        if (absolute_idDiff%9 == 0|| absolute_idDiff%7 == 0){
                            if (current_space_color == past_space_color){
                                return true;
                            }
                        }
                        break;
                    case "black-knight":
                    case "white-knight":    
                        if (absolute_idDiff == 15 || absolute_idDiff == 17 || absolute_idDiff == 10 || absolute_idDiff == 6){
                            return true;
                        }
                        break;
                    case "black-king":
                    case "white-king":
                        if (absolute_idDiff == 8){
                            return true;
                        } else if (absolute_idDiff == 1){
                            return true;
                        } else if (absolute_idDiff == 9 || absolute_idDiff == 7){
                            return true;
                        }
                        break;
                    case "black-queen":
                    case "white-queen":
                        if (idDiff%8 == 0){
                            return true;
                        }else if (absolute_idDiff%9 == 0|| absolute_idDiff%7 == 0 && current_space_color == past_space_color){
                            return true;
                        }else{
                                var lastIdPast = parseInt(id/8);
                                 
                                var lowerBoundry = (lastIdPast * 8) + 1;
                                 
                                var upperBoundry = lowerBoundry+8;
                                 
                                if(upperBoundry >= currentId && currentId >=lowerBoundry ){
                                    return true;
                                }else{
                                    return false;
                                }
                        }
                    return false;
                }
            }
            function getColor(selector){
                var id = document.getElementById(selector)
                var teamColorUnprocessed = id.className.split('-')[0];
